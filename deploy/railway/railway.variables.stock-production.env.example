# Odoo 19 stock production template — paste onto Railway Odoo service
# SSOT manifest: deploy/railway/stock-production.deploy.json
# NOT factory template 2 (no CONFIG_PROFILE / ODOO_DB / PGHOST / entrypoint-odoo-app.sh)

TZ=America/New_York
PORT=8069
HOME=/var/lib/odoo
RAILWAY_RUN_UID=0

# Enterprise image (odoo-19-1e Dockerfile)
ODOO_ADDONS_PATH=/usr/lib/python3/dist-packages/odoo/addons,/opt/odoo/enterprise,/mnt/extra-addons

# Postgres wiring (stock template — service name Postgres)
ODOO_DATABASE_HOST=${{Postgres.RAILWAY_PRIVATE_DOMAIN}}
ODOO_DATABASE_PORT=5432
ODOO_DATABASE_USER=${{Postgres.POSTGRES_USER}}
ODOO_DATABASE_PASSWORD=${{Postgres.POSTGRES_PASSWORD}}
ODOO_DATABASE_NAME=${{Postgres.POSTGRES_DB}}

# SMTP (stock template defaults)
ODOO_SMTP_HOST=mail.rg1.io
ODOO_SMTP_PORT_NUMBER=587
ODOO_SMTP_USER=admin@mvs.rg1.io
ODOO_EMAIL_FROM=admin@mvs.rg1.io
ODOO_SMTP_PASSWORD=<fill-from-y_secrets>

# Postgres service variables (paste on Postgres service, not Odoo)
# POSTGRES_DB=odoo
# POSTGRES_USER=odoo
# POSTGRES_PASSWORD=odoo
# TZ=America/New_York
