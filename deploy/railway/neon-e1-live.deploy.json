{
  "$schema": "odoo-19-1e-neon-live/v1",
  "description": "joyful-friendship live: FROM evoluzion26/odoo-19-e1 + Neon. Official Odoo Docker env vars only.",
  "reference": {
    "project_id": "2a51ef71-b79e-4492-ac8c-c7aaef65c342",
    "environment_id": "c5867796-c797-4bc9-8735-6171cca0e862",
    "service_id": "44c86b74-78d9-4000-b386-a83f762d58c1",
    "service_name": "joyful-friendship"
  },
  "image_base": "evoluzion26/odoo-19-e1:latest",
  "neon": {
    "project_id": "old-fire-25624020",
    "branch_id": "br-withered-scene-a6vicuxr",
    "database_name": "odoo-19-e1"
  },
  "git": {
    "repo": "rjr3000/odoo-19-1e",
    "branch": "master",
    "railway_config_file": "/railway.json",
    "root_directory": "build-context"
  },
  "deploy": {
    "startCommand": "/entrypoint.sh odoo --db_sslmode=require --proxy-mode --database odoo-19-e1 -i base",
    "healthcheckPath": "/web/health",
    "healthcheckTimeout": 900
  },
  "variables": {
    "TZ": "America/New_York",
    "PGPORT": "5432",
    "PGDATABASE": "odoo-19-e1",
    "PGSSLMODE": "require"
  },
  "notes": {
    "db_env": "PGHOST/PGPORT/PGUSER/PGPASSWORD — Odoo entrypoint reads these; avoids Railway PORT=8069 conflict.",
    "enterprise": "Baked in evoluzion26/odoo-19-e1 at /opt/odoo/enterprise — no zip, no release URL.",
    "first_boot": "startCommand includes -i base once; remove -i base after DB is initialized."
  }
}
