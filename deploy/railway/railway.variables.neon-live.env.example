# odoo-19-1e live environment — Neon database (paste on Railway service)
# Enterprise is BAKED in image from build-context/enterprise-addons.zip — no release URL.

TZ=America/New_York
PORT=8069
HOME=/var/lib/odoo
RAILWAY_RUN_UID=0
PGSSLMODE=require
ENTERPRISE_DELIVERY=baked

ODOO_ADDONS_PATH=/usr/lib/python3/dist-packages/odoo/addons,/opt/odoo/enterprise,/mnt/extra-addons

ODOO_DATABASE_HOST=<neon-pooler-host>
ODOO_DATABASE_PORT=5432
ODOO_DATABASE_USER=neondb_owner
ODOO_DATABASE_PASSWORD=<neon-secret>
ODOO_DATABASE_NAME=odoo-19-e1

NEON_PROJECT_ID=old-fire-25624020
NEON_PARENT_BRANCH=main

ODOO_SMTP_HOST=mail.rg1.io
ODOO_SMTP_PORT_NUMBER=587
ODOO_SMTP_USER=admin@mvs.rg1.io
ODOO_EMAIL_FROM=admin@mvs.rg1.io
ODOO_SMTP_PASSWORD=<fill-from-y_secrets>

# Railway: /railway.json, rootDirectory=build-context, volume /var/lib/odoo, port 8069
