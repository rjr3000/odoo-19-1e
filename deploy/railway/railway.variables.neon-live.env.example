# odoo-19-1e live environment — Neon database (paste on Railway odoo-19-1e service)
# SSOT manifest: deploy/railway/neon-e1-live.deploy.json
# Apply: python deploy/railway/scripts/setup-live-neon-e1.py

TZ=America/New_York
PORT=8069
HOME=/var/lib/odoo
RAILWAY_RUN_UID=0
PGSSLMODE=require

# Standard Odoo 19 + baked enterprise paths
ODOO_ADDONS_PATH=/usr/lib/python3/dist-packages/odoo/addons,/opt/odoo/enterprise,/mnt/extra-addons

# Neon project odoo-19-e1 / database odoo-19-e1 (setup script fills host/user/password)
ODOO_DATABASE_HOST=<neon-pooler-host>
ODOO_DATABASE_PORT=5432
ODOO_DATABASE_USER=neondb_owner
ODOO_DATABASE_PASSWORD=<neon-secret>
ODOO_DATABASE_NAME=odoo-19-e1

# Build-time enterprise fetch (Dockerfile ARG — baked to /opt/odoo/enterprise)
ENTERPRISE_DELIVERY=baked
ENTERPRISE_ZIP_URL=https://github.com/rjr3000/odoo-19-all/releases/download/enterprise-latest/enterprise-addons.zip
GH_ADDONS_TOKEN=<from-y_secrets-GITHUB_TOKEN>

# Neon metadata
NEON_PROJECT_ID=old-fire-25624020
NEON_PARENT_BRANCH=main

# SMTP
ODOO_SMTP_HOST=mail.rg1.io
ODOO_SMTP_PORT_NUMBER=587
ODOO_SMTP_USER=admin@mvs.rg1.io
ODOO_EMAIL_FROM=admin@mvs.rg1.io
ODOO_SMTP_PASSWORD=<fill-from-y_secrets>

# Railway service settings (also in /railway.json)
# Config file path: /railway.json
# Builder: DOCKERFILE → build-context/Dockerfile
# Git repo: rjr3000/odoo-19-1e branch master
# Volume: /var/lib/odoo
# Target port: 8069
# Healthcheck: /web/health
