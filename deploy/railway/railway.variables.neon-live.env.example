# PG* vars — Odoo /entrypoint.sh reads these (avoids Railway PORT=8069 conflict)

PGHOST=<neon-pooler-host>
PGPORT=5432
PGUSER=neondb_owner
PGPASSWORD=<neon-password>
PGDATABASE=odoo-19-e1
PGSSLMODE=require
TZ=America/New_York

# Railway: /railway.json, rootDirectory=build-context, volume /var/lib/odoo, port 8069
# First boot only: startCommand includes -i base (see neon-e1-live.deploy.json)
