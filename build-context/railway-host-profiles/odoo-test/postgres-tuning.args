# Railway r2-test — same dev-class Postgres footprint as r2-dev
-c shared_buffers=128MB
-c effective_cache_size=512MB
-c work_mem=32MB
-c maintenance_work_mem=128MB
-c random_page_cost=1.1
-c effective_io_concurrency=100
-c max_connections=40
-c checkpoint_completion_target=0.9
-c wal_buffers=16MB
-c default_statistics_target=100
-c max_worker_processes=2
-c max_parallel_workers=1
-c max_parallel_workers_per_gather=1
-c max_parallel_maintenance_workers=1
-c statement_timeout=15min
-c idle_in_transaction_session_timeout=20min
-c lock_timeout=10s
-c shared_preload_libraries=pg_stat_statements,pg_cron,pg_textsearch
-c cron.database_name=${POSTGRES_DB}
-c log_min_duration_statement=2000
-c autovacuum_vacuum_scale_factor=0.05
-c autovacuum_analyze_scale_factor=0.02
