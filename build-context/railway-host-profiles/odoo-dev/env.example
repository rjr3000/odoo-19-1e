# r2-dev profile — reference only. Branch previews copy dev1 app vars; PGHOST is each
# env's db service private domain (set at deploy time, not hardcoded in CI).
ADDONS_GIT_REPO=rjr3000/odoo-19-all
ADDONS_GIT_REF=<branch-sha>
CONFIG_PROFILE=r2-dev
ODOO_DB=r2_dev
ODOO_LIST_DB=1
ODOO_LIST_ADDONS=1
ODOO_BASE_MODULES=base,web
ODOO_CUSTOM_MODULES=ev_filter,ev_dm,ev_ep,ev_sp
PGHOST=<env-db RAILWAY_PRIVATE_DOMAIN>
PGPORT=5432
