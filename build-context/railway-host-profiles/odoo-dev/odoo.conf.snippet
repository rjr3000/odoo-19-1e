; hosts/r2-dev — dev / PR (S10-odoo-dev-mode: xml,qweb for fast view/QWeb iteration)
; db_name and dbfilter are set at boot from ODOO_DB / ODOO_DBFILTER (entrypoint-odoo-app.sh)
list_db = False
db_port = 5432

