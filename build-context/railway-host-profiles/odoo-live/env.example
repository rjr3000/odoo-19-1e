# r2-live profile — reference only. CI canonical-deploy copies live app vars from Railway
# and sets PGHOST from the live db service private domain (not a static hostname).
ADDONS_GIT_REPO=rjr3000/odoo-19-all
ADDONS_GIT_REF=main
CONFIG_PROFILE=r2-live
ODOO_DB=r2_live
PGHOST=<live-db RAILWAY_PRIVATE_DOMAIN>
PGPORT=5432
ODOO_MODULE_SYNC=1
