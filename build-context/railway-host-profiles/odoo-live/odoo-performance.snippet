# Live parity Odoo HTTP + worker settings (merge into odoo-app-1 odoo.conf)
proxy_mode = True
http_interface = 0.0.0.0
http_port = 8069
gevent_port = 8072
server_wide_modules = base,rpc,web
workers = 5
max_cron_threads = 1
limit_time_cpu = 600
limit_time_real = 1200
limit_time_real_cron = 1200
limit_memory_soft = 1073741824
limit_memory_hard = 1879048192
log_level = info
